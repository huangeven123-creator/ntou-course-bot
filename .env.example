# LINE Messaging API Configurations
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Firebase Configurations (JSON service account key represented as a one-line string or local file path)
# Option A: JSON string
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
# Option B: Path to the JSON service account file
FIREBASE_KEY_FILE_PATH=./firebase-key.json

# API Security Configurations
CRON_SECRET=your_custom_secret_to_protect_cron_endpoint
PORT=8000
